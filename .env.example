# URL base del backend, incluyendo /api.
# Vacia o ausente = se usa la ruta relativa /api, que en desarrollo resuelve el
# proxy de Vite contra localhost:7002.
# En produccion se configura en el panel del hosting, NO en este archivo.
NUXT_PUBLIC_API_BASE=

# URL publica del sitio, usada para la imagen OG en `nuxt generate`.
NUXT_PUBLIC_SITE_URL=
