# URL base del backend, SIN /api al final.
# La usa el proxy de server/api/[...ruta].js, que corre del lado del servidor.
# Si no se define, cae a http://localhost:7002, que es donde escucha el backend
# en desarrollo.
# En produccion se configura en el panel del hosting, NO en este archivo.
API_BASE=

# URL publica del sitio, usada para la imagen OG en `nuxt generate`.
NUXT_PUBLIC_SITE_URL=
